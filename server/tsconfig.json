{
  "compilerOptions": {
    "target": "ES2020", 
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowJs": true,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*"]
}